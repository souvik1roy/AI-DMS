# UI build-time configuration. Copy to `.env.local` for local prod-mode preview;
# in Vercel set these in Project Settings → Environment Variables.

# The base URL of the sidecar (Render service).
VITE_DMS_BASE_URL=https://your-sidecar.onrender.com

# The bearer token the sidecar requires on every request. Must match the
# `DMS_BEARER_TOKEN` env var on the Render service.
VITE_DMS_TOKEN=replace_with_long_random_string
