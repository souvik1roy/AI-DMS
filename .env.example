# --- Backend (sidecar) -------------------------------------------------------
# These go in Render service env vars (NOT committed); copy to sidecar/.env for
# local dev with scripts/dev-browser.sh.

DMS_BEARER_TOKEN=replace_with_long_random_string
OPENAI_API_KEY=sk-...
OPENAI_VISION_MODEL=gpt-4o
OPENAI_REASONER_MODEL=gpt-4o

SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-...pooler.supabase.com:6543/postgres

# Comma-separated list of origins permitted by CORS (the UI's URL).
WEB_ORIGIN=http://localhost:5173,https://your-app.vercel.app

# Optional overrides
DMS_STAGING_BUCKET=staging
DMS_ORGANIZED_BUCKET=organized
DMS_SIGNED_URL_TTL=3600

# --- Frontend (UI) -----------------------------------------------------------
# These go in Vercel project env vars (and ui/.env.local for local dev).

VITE_DMS_BASE_URL=https://your-sidecar.onrender.com
VITE_DMS_TOKEN=replace_with_long_random_string
